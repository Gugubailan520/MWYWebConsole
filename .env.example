# 服务器端口
PORT=3000

# Guacamole 配置
# guacamole-lite 内部 WebSocket 端口（仅监听 127.0.0.1，不对外暴露）
GUAC_WS_PORT=4823

# guacd 守护进程地址（默认同机部署）
GUACD_HOST=127.0.0.1
GUACD_PORT=4822

# AES-256-CBC 加密密钥（必须恰好 32 字符，生产环境请修改！）
GUAC_CRYPT_KEY=MWYwebConsole-GuacLite!!-Secret!!

# 运行 guacd（选一种方式）:
# 方式1 - Docker:  docker run -d --name guacd -p 4822:4822 guacamole/guacd
# 方式2 - Debian:  apt install guacd && systemctl start guacd
# 方式3 - 同容器:  见 docker-compose.yml 中 guacd service
